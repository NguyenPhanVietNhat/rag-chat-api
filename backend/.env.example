# ── Bắt buộc ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here

# ── Auth  ────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
TOKEN_EXPIRE_MIN=1440

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db
MAX_FILE_MB=50

# ── RAG tuning ────────────────────────────────────────────────────────────────
EMBED_MODEL=multilingual-default
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=5
MIN_SCORE=0.20

# ── Server ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://localhost:8000,http://127.0.0.1:5500,http://127.0.0.1:8000